{
  "compilerOptions": {
    "target": "es2022",                  
    "module": "commonjs",                
    "strict": true,                      
    "esModuleInterop": true,             
    "skipLibCheck": true,              
    "allowJs": true,                      
    "resolveJsonModule": true,           
    "isolatedModules": true,             
    "jsx": "react-jsx",                  
    "outDir": "./dist",                  
    "baseUrl": ".",                      
    "moduleResolution": "node",
    "paths": {                           
      "@components/*": ["src/components/*"]
    },
    "types": ["node"],
     "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*"],               
  "exclude": ["node_modules", "dist"]    
}
