{
  "compilerOptions": {
    "target": "es2022",                  
    "module": "commonjs",                
    "strict": true,                      
    "esModuleInterop": true,             
    "skipLibCheck": true,              
    "allowJs": true,                      
    "resolveJsonModule": true,           
    "isolatedModules": true,             
    "jsx": "react-jsx",                  
    "outDir": "./dist",                  
    "baseUrl": ".",                      
    "paths": {                           
      "@components/*": ["src/components/*"]
    }
  },
  "include": ["src/**/*"],               
  "exclude": ["node_modules", "dist"]    
}
